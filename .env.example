# Copy to .env and fill in. The CLI loads this automatically (python-dotenv).
# Real exported environment variables always take precedence over this file.

# Tag generation — set the key for whichever --provider you use.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Manyfold upload (optional). MANYFOLD_API_URL is the instance ROOT (not /api).
# MANYFOLD_API_URL=https://manyfold.example.net
# MANYFOLD_API_TOKEN=
# or OAuth client credentials (Manyfold's only auth):
# MANYFOLD_CLIENT_ID=
# MANYFOLD_CLIENT_SECRET=
# MANYFOLD_LIBRARY_PATH=
# OAuth scopes to request (default: public read write). The OAuth application
# must be granted these in Manyfold; override only if yours differs.
# MANYFOLD_SCOPES=public read write
